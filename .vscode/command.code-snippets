{
  "command": {
    "prefix": "command",

    "body": [
      "import { Command } from 'commander';",
      "",
      "export type $1Options = {",
      "  name: string;",
      "};",
      "",
      "export class $1Command {",
      "",
      "  bind(program: Command) {",
      "    program",
      "      .command('$1')",
      "      .description('$1')",
      "      .requiredOption('-n,--name <string> some description')",
      "      .action(this.run);",
      "  }",
      "  ",
      "  run(options: $1Options) {",
      "    console.log(`Hello, ${options.name}`);",
      "  }",
      "}"
    ],
    "scope": "typescript"
  }
}
