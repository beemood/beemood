{
  "name": "@beemood/todo-db",
  "version": "0.0.1",
  "description": "Todo database",
  "keywords": [
    "library"
  ],
  "homepage": "/dbs/todo-db",
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "icon": "https://raw.githubusercontent.com/beemood/beemood/refs/heads/main/dbs/todo-db/favicon.png",
  "repository": {
    "url": "https://github.com/beemood/beemood/tree/main/dbs/todo-db",
    "type": "github"
  },
  "author": {
    "name": "Robert",
    "email": "robert.brightline@gmail.com",
    "url": "https://beemood.github.io"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "dbs/todo-db/dist",
          "main": "dbs/todo-db/src/index.ts",
          "tsConfig": "dbs/todo-db/tsconfig.lib.json",
          "format": [
            "esm"
          ],
          "declarationRootDir": "dbs/todo-db/src"
        }
      },
      "doc": {
        "command": "npx typedoc --options {projectRoot}/typedoc.json --favicon {projectRoot}/favicon.png --entryPoints {projectRoot}/src/index.ts --out public/{projectRoot} --tsconfig {projectRoot}/tsconfig.lib.json"
      },
      "prisma:migrate": {
        "command": "npx prisma migrate deve --name some",
        "options": {
          "cwd": "dbs/todo-db"
        }
      },
      "prisma:generate": {
        "command": "npx prisma generate",
        "options": {
          "cwd": "dbs/todo-db"
        }
      }
    }
  },
  "dependencies": {
    "@beemood/nest": "workspace:*",
    "@beemood/property": "workspace:*",
    "@prisma/client": "6.11.1"
  }
}
