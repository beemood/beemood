{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "type": { "const": "integer" },
    "minimum": { "type": "integer" },
    "maximum": { "type": "integer" },
    "isIn": { "type": "array", "items": { "type": "integer" } },
    "notIn": { "type": "array", "items": { "type": "integer" } },
    "format": { "$ref": "../enum/integer-format.schema.json" },
    "defaultValue": { "type": "integer", "default": 0 },
    "example": { "type": "integer", "default": 0 },
    "examples": {
      "type": "array",
      "items": { "type": "integer" },
      "default": [0]
    }
  },
  "required": ["type"]
}
