generator client {
  provider = "prisma-client"
  output   = "../src/lib/prisma"
}

generator zod {
  provider = "beemood-prisma"
  output   = "../src/lib/zod.ts"
  kind     = "zod"
  project  = "@beemood/sample-db"
}

generator swagger {
  provider = "beemood-prisma"
  output   = "../src/lib/swagger.ts"
  kind     = "swagger"
  project  = "@beemood/sample-db"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  Active
  Passive
}

model Attribute {
  id       Int     @id @default(autoincrement())
  sample   Sample? @relation(fields: [sampleId], references: [id])
  sampleId Int?
}

model Sample {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  uuid String @unique @default(uuid(7))
  name String @unique @db.VarChar(255)

  price Decimal @db.Decimal(8, 2)

  notes String[]

  status Status

  attributes Attribute[]

  @@index([status])
}
