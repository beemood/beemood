{
  "name": "@beemood/nestjs",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@beemood/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "libs/nestjs/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/nestjs/dist",
          "main": "libs/nestjs/src/index.ts",
          "tsConfig": "libs/nestjs/tsconfig.lib.json",
          "skipTypeCheck": true,
          "stripLeadingPaths": true
        }
      }
    }
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.9"
  },
  "dependencies": {
    "@beemood/errors": "workspace:*",
    "@beemood/registry": "workspace:*",
    "@beemood/types": "workspace:*",
    "@nestjs/core": "^11.1.9",
    "@swc/helpers": "~0.5.11"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.9"
  }
}
