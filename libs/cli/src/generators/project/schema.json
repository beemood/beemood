{
  "$schema": "https://json-schema.org/schema",
  "$id": "Project",
  "title": "Project generator options",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use?"
    },
    "projectType": {
      "type": "string",
      "description": "",
      "enum": ["api", "cli", "lib"],
      "$default": {
        "$source": "argv",
        "index": 1
      },
      "x-prompt": "What is the project projectType?"
    }
  },
  "required": ["name", "type"]
}
