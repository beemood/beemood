{
  "name": "@bmod/gen",
  "version": "0.3.5",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "license": "MIT",
  "description": "Project and resource generators",
  "author": {
    "email": "robert.brightline@gmail.com",
    "name": "Robert Brightline",
    "url": "https://beemood.github.io"
  },
  "keywords": [
    "beemood",
    "generator"
  ],
  "repository": {
    "directory": "libs/gen",
    "url": "https://github.com/beemood/beemood/tree/main",
    "type": "github"
  },
  "homepage": "https://rbrightline.github.io/beemood/gen",
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "icon": "https://raw.githubusercontent.com/beemood/beemood/refs/heads/main/libs/gen/favicon.png",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "generators.json",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "libs/gen/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "{projectRoot}/dist",
          "main": "{projectRoot}/src/index.ts",
          "tsConfig": "{projectRoot}/tsconfig.lib.json",
          "skipTypeCheck": false,
          "stripLeadingPaths": true,
          "assets": [
            {
              "input": "./libs/gen/src",
              "glob": "**/!(*.ts)",
              "output": "."
            },
            {
              "input": "./libs/gen/src",
              "glob": "**/*.d.ts",
              "output": "."
            }
          ]
        }
      },
      "doc": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npx typedoc --tsconfig {projectRoot}/tsconfig.lib.json --entryPoints {projectRoot}/src/index.ts --out public/{projectRoot}",
          "cwd": "{workspaceRoot}"
        }
      }
    }
  },
  "dependencies": {
    "@nx/devkit": "21.0.2",
    "@swc/helpers": "~0.5.11"
  },
  "generators": "./generators.json"
}
