{
  "name": "@bmod/gen",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "generators.json",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "libs/gen/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/gen/dist",
          "main": "libs/gen/src/index.ts",
          "tsConfig": "libs/gen/tsconfig.lib.json",
          "skipTypeCheck": false,
          "stripLeadingPaths": true,
          "assets": [
            {
              "input": ".libs/gen/src",
              "glob": "**/!(*.ts)",
              "output": "."
            },
            {
              "input": "libs/gen/src",
              "glob": "**/*.d.ts",
              "output": "."
            }
          ]
        }
      }
    }
  },
  "dependencies": {
    "@nx/devkit": "21.0.2",
    "@swc/helpers": "~0.5.11"
  },
  "generators": "./generators.json"
}
