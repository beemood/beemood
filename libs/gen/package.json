{
  "name": "@bmod/gen",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "generators.json"
  ],
  "nx": {
    "sourceRoot": "libs/gen/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/gen/dist",
          "main": "libs/gen/src/index.ts",
          "tsConfig": "libs/gen/tsconfig.lib.json",
          "skipTypeCheck": false,
          "stripLeadingPaths": true,
          "assets": [
            {
              "input": "libs/gen/src",
              "glob": "**/*.json",
              "output": "/"
            },
            {
              "input": "libs/gen/src",
              "glob": "**/*.d.ts",
              "output": "/"
            }
          ]
        }
      }
    }
  },
  "dependencies": {
    "@nx/devkit": "20.7.1",
    "@swc/helpers": "~0.5.11"
  },
  "generators": "./generators.json"
}
