{
  "name": "@beemood/nestjs-prisma",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@beemood/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "libs/nestjs-prisma/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "libs/nestjs-prisma/dist",
          "main": "libs/nestjs-prisma/src/index.ts",
          "tsConfig": "libs/nestjs-prisma/tsconfig.lib.json",
          "skipTypeCheck": true,
          "stripLeadingPaths": true
        }
      }
    }
  },
  "peerDependencies": {
    "@beemood/nestjs": "workspace:*",
    "@beemood/types": "workspace:*",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "express": "^5.2.1"
  },
  "dependencies": {
    "@beemood/names": "workspace:*",
    "@swc/helpers": "~0.5.11"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
}