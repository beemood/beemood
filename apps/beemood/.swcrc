{
  "minify": true,
  "jsc": {
    "target": "es2017",
    "minify": {
      "mangle": true,
      "keep_classnames": true,
      "keep_fnames": true
    },
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "decoratorMetadata": true,
      "legacyDecorator": true
    },
    "keepClassNames": true,
    "externalHelpers": true,
    "loose": true
  },
  "module": {
    "type": "es6"
  },
  "sourceMaps": true,
  "exclude": ["vite.config.ts*", ".*.js$"]
}
