{
  "name": "@bmod/auth-api",
  "version": "0.0.1",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "description": "- [ ] add description to auth-api",
  "author": {
    "email": "robert.brightline@gmail.com",
    "name": "Robert Brightline",
    "url": "https://beemood.github.io"
  },
  "keywords": [
    "- [ ] add keywords to auth-api"
  ],
  "repository": {
    "directory": "apps/auth-api",
    "url": "https://github.com/beemood/beemood/tree/main",
    "type": "github"
  },
  "homepage": "https://beemood.github.io/beemood/auth-api",
  "bugs": {
    "email": "robert.brightline@gmail.com",
    "url": "https://beemood.github.io"
  },
  "categories": [
    "AI"
  ],
  "contributors": [
    {
      "email": "robert.brightline@gmail.com",
      "name": "Robert Brightline",
      "url": "https://beemood.github.io"
    }
  ],
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "icon": "https://raw.githubusercontent.com/beemood/beemood/refs/heads/main/apps/auth-api/favicon.png",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "auth-api": "./bin/auth-api.js"
  },
  "files": [
    "bin",
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "postinstall": "npx prisma generate"
  },
  "nx": {
    "sourceRoot": "apps/auth-api/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "apps/auth-api/dist",
          "main": "apps/auth-api/src/index.ts",
          "tsConfig": "apps/auth-api/tsconfig.lib.json",
          "skipTypeCheck": false,
          "stripLeadingPaths": true
        }
      },
      "doc": {
        "command": "npx typedoc --entryPoints apps/auth-api/src/index.ts --out public/apps/auth-api --tsconfig apps/auth-api/tsconfig.lib.json"
      },
      "build-watch": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "apps/auth-api/dist",
          "main": "apps/auth-api/src/index.ts",
          "tsConfig": "apps/auth-api/tsconfig.lib.json",
          "skipTypeCheck": true,
          "stripLeadingPaths": true,
          "watch": true
        }
      },
      "start": {
        "command": "node --watch --watch-path=src ./dist/run-dev.js ",
        "options": {
          "cwd": "apps/auth-api"
        }
      },
      "serve": {
        "dependsOn": [
          "build-watch",
          "start"
        ]
      }
    }
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "@nestjs/common": "^11.0.13",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.13",
    "@nestjs/platform-fastify": "^11.0.13",
    "@nestjs/swagger": "^11.1.1",
    "@swc/helpers": "^0.5.15",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "commander": "^13.1.0",
    "helmet": "^8.1.0",
    "pg": "^8.14.1",
    "typeorm": "^0.3.22"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.13",
    "@prisma/client": "6.6.0",
    "@types/helmet": "^4.0.0",
    "chokidar": "^4.0.3",
    "prisma": "^6.5.0"
  }
}
