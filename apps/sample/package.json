{
  "name": "@beemood/sample",
  "version": "0.0.1",
  "private": true,
  "keywords": [
    "api"
  ],
  "homepage": "/apps/sample",
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "icon": "https://raw.githubusercontent.com/beemood/beemood/refs/heads/main/apps/sample/favicon.png",
  "repository": {
    "url": "https://github.com/beemood/beemood/tree/main/apps/sample",
    "type": "github"
  },
  "author": {
    "name": "Robert",
    "email": "robert.brightline@gmail.com",
    "url": "https://beemood.github.io"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "platform": "node",
          "outputPath": "apps/sample/dist",
          "format": [
            "cjs"
          ],
          "bundle": false,
          "main": "apps/sample/src/main.ts",
          "tsConfig": "apps/sample/tsconfig.app.json",
          "assets": [
            "apps/sample/src/assets"
          ],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": {
              ".js": ".js"
            }
          }
        },
        "configurations": {
          "development": {},
          "production": {
            "esbuildOptions": {
              "sourcemap": false,
              "outExtension": {
                ".js": ".js"
              }
            }
          }
        }
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@beemood/sample:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@beemood/sample:build:development"
          },
          "production": {
            "buildTarget": "@beemood/sample:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      },
      "doc": {
        "command": "npx typedoc --options {projectRoot}/typedoc.json --favicon {projectRoot}/favicon.png --entryPoints {projectRoot}/src/main.ts --out public/{projectRoot} --tsconfig {projectRoot}/tsconfig.app.json"
      }
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "helmet": "^8.1.0"
  }
}
