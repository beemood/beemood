generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

enum CustomerStatus {
  CUSTOMER
  PROSPECT
  PARTNER
  FORMER_CUSTOMER
}

enum MeetingType {
  PHONE_CALL
  VIDEO_CALL
  IN_PERSON
}

enum MeetingPlace {
  ONLINE
  OUR_OFFICE
  CUSTOMER_OFFICE
  RESTORANT
  CAFE
}

enum CustomerProductPotential {
  UNKNOWN
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

model Employee {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employeeId Int

  MeetingInstructor MeetingInstructor[]
  MeetingEmployee   MeetingEmployee[]
}

model Product {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  productId Int

  MeetingProduct  MeetingProduct[]
  CustomerProduct CustomerProduct[]
}

model CustomerProduct {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  potential CustomerProductPotential @default(UNKNOWN)

  notes String @default("Add product features that the customer like")

  Product   Product @relation(fields: [productId], references: [id])
  productId Int
}

model Customer {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  customerId Int

  potential CustomerProductPotential @default(UNKNOWN)

  MeetingCustomer MeetingCustomer[]
}

model MeetingInstructor {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  Employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int

  Meeting   Meeting @relation(fields: [meetingId], references: [id])
  meetingId Int
}

model MeetingEmployee {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  Employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int

  Meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId Int
}

model MeetingProduct {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  Product   Product @relation(fields: [productId], references: [id])
  productId Int

  Meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId Int
}

model MeetingCustomer {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  Cusstomer  Customer @relation(fields: [customerId], references: [id])
  customerId Int

  Meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId Int
}

model MeetingNote {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  note String

  Meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId Int
}

model Meeting {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  startDate DateTime
  endDate   DateTime?

  goal    String
  outcome String?

  type  MeetingType  @default(PHONE_CALL)
  place MeetingPlace @default(ONLINE)

  MeetingNote MeetingNote[]

  MeetingInstructor MeetingInstructor[]
  MeetingEmployee   MeetingEmployee[]
  MeetingCustomer   MeetingCustomer[]
  MeetingProduct    MeetingProduct[]
}
