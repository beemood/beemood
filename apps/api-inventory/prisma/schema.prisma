generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

model Category {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name String @unique

  Product Product[]
}

model Department {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name String @unique

  Product Product[]
}

model Tag {
  id Int @id @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name    String
  Product Product[]
}

model Product {
  id Int @id @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name        String @unique
  description String @default("Product does not have a description!")
  barcode     String @unique @default(uuid())

  brand String?

  Department   Department? @relation(fields: [departmentId], references: [id])
  departmentId Int?

  Category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId Int?

  Tag   Tag? @relation(fields: [tagId], references: [id])
  tagId Int?

  ProductVariant ProductVariant[]
}

model ProductAttribute {
  id Int @id @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  key   String
  value String

  ProductVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  productVariantId Int?

  @@unique([key, value, productVariantId])
}

model ProductVariant {
  id Int @id @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sku     String @unique
  barcode String @unique

  trackSerialNumber Boolean?

  Product   Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId Int

  ProductAttribute ProductAttribute[]
  Price            Price[]
  Quantity         Quantity[]
  SerialNumber     SerialNumber[]
}

model PriceLevel {
  id        Int       @id @unique @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name    String  @unique
  taxrate Decimal @default(0)

  Price Price[]
  Store Store[]
}

model Price {
  id        Int       @id @unique @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  cost  Decimal
  price Decimal

  ProductVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  productVariantId Int

  PriceLevel   PriceLevel @relation(fields: [priceLevelId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  priceLevelId Int
}

model Quantity {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  quantity        Int
  minumumQuantity Int? @default(0)

  ProductVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  productVariantId Int

  Store   Store @relation(fields: [storeId], references: [id])
  storeId Int
}

model SerialNumber {
  id Int @id @unique @default(autoincrement())

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  serialNumber String @unique

  ProductVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  productVariantId Int

  Store   Store @relation(fields: [storeId], references: [id])
  storeId Int
}

model Store {
  id        Int       @id @unique @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name String @unique

  PriceLevel   PriceLevel @relation(fields: [priceLevelId], references: [id])
  priceLevelId Int

  Quantity     Quantity[]
  SerialNumber SerialNumber[]
}
