{
  "name": "@bmod/pms-db",
  "version": "0.0.1",
  "description": "Useful cli pms-db to use accrosss the projects",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "author": {
    "email": "robert.brightline@gmail.com",
    "name": "Robert Brightline",
    "url": "https://beemood.github.io"
  },
  "keywords": [
    "pms-db"
  ],
  "repository": {
    "directory": "db/pms-db",
    "url": "https://github.com/beemood/beemood/tree/main",
    "type": "github"
  },
  "homepage": "https://beemood.github.io/beemood/pms-db",
  "bugs": {
    "email": "robert.brightline@gmail.com",
    "url": "https://beemood.github.io"
  },
  "categories": [
    "AI"
  ],
  "contributors": [
    {
      "email": "robert.brightline@gmail.com",
      "name": "Robert Brightline",
      "url": "https://beemood.github.io"
    }
  ],
  "funding": [
    "https://cash.app/$puqlib"
  ],
  "icon": "https://raw.githubusercontent.com/beemood/beemood/refs/heads/main/db/pms-db/favicon.png",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pms-db": "./bin/pms-db.js"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "postinstall": "npx prisma generate"
  },
  "nx": {
    "sourceRoot": "db/pms-db/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "db/pms-db/dist",
          "main": "db/pms-db/src/index.ts",
          "tsConfig": "db/pms-db/tsconfig.lib.json",
          "skipTypeCheck": false,
          "stripLeadingPaths": true
        }
      },
      "doc": {
        "command": "npx typedoc --entryPoints db/pms-db/src/index.ts --out public/db/pms-db --tsconfig db/pms-db/tsconfig.lib.json"
      },
      "prisma-generate": {
        "command": "npx prisma generate",
        "options": {
          "cwd": "db/pms-db"
        }
      },
      "prisma-migrate": {
        "command": "npx prisma migrate dev --name init",
        "options": {
          "cwd": "db/pms-db"
        }
      }
    }
  },
  "dependencies": {
    "@swc/helpers": "^0.5.15",
    "commander": "^13.1.0"
  }
}
