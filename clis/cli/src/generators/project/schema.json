{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "Project",
  "title": "Project Generator",
  "type": "object",
  "properties": {
    "projectName": {
      "type": "string",
      "description": "Project name",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What projectName would you like to use?"
    },
    "projectType": {
      "type": "string",
      "description": "Project type",
      "enum": ["api", "cli", "lib", "util", "db"],
      "$default": {
        "$source": "argv",
        "index": 1
      },
      "x-prompt": "What project-type would you like to use?"
    }
  },
  "required": ["projectName", "projectType"]
}
